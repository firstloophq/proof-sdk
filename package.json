{
  "name": "proof-sdk",
  "version": "0.1.0",
  "description": "Open-source collaborative markdown editor with provenance tracking and an agent HTTP bridge",
  "private": false,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "docker compose down --remove-orphans 2>/dev/null; docker compose up --build -d && echo '' && echo '  Proof SDK running at: http://localhost:4000' && echo '' && docker compose watch",
    "dev:local": "vite",
    "build": "vite build && node scripts/finalize-web-build.mjs",
    "serve": "bun run server/index.ts",
    "test": "npm run test:proof-sdk && npm run test:server-routes-share",
    "test:proof-sdk": "tsx src/tests/proof-sdk-agent-bridge-client.test.ts",
    "test:server-routes-share": "tsx src/tests/server-routes-and-share.test.ts",
    "demo:agent": "npm --workspace proof-example run demo:agent"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.879.0",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@handlewithcare/prosemirror-suggest-changes": "^0.1.8",
    "@hocuspocus/provider": "^2.15.2",
    "@hocuspocus/server": "^2.15.2",
    "@milkdown/core": "^7.5.0",
    "@milkdown/kit": "^7.19.0",
    "@milkdown/plugin-clipboard": "^7.5.0",
    "@milkdown/plugin-collab": "^7.18.0",
    "@milkdown/plugin-cursor": "^7.5.0",
    "@milkdown/plugin-history": "^7.5.0",
    "@milkdown/plugin-listener": "^7.5.0",
    "@milkdown/plugin-prism": "^7.18.0",
    "@milkdown/preset-commonmark": "^7.5.0",
    "@milkdown/preset-gfm": "^7.5.0",
    "@milkdown/prose": "^7.19.0",
    "@milkdown/theme-nord": "^7.5.0",
    "@milkdown/transformer": "^7.19.0",
    "@resvg/resvg-js": "^2.6.2",
    "beautiful-mermaid": "^1.1.3",
    "better-sqlite3": "^12.6.2",
    "express": "^5.2.1",
    "lib0": "^0.2.117",
    "prismjs": "^1.30.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "satori": "^0.24.1",
    "unified": "^11.0.5",
    "web-haptics": "^0.0.6",
    "wink-eng-lite-web-model": "^1.2.1",
    "wink-nlp": "^2.1.0",
    "ws": "^8.19.0",
    "y-indexeddb": "^9.0.12",
    "y-prosemirror": "^1.2.19",
    "y-protocols": "^1.0.7",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.20",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^20.10.0",
    "@types/prismjs": "^1.26.5",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
